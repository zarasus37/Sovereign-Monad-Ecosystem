{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GnosisScore",
  "type": "object",
  "properties": {
    "agentId": { "type": "string" },
    "windowStart": { "type": "string", "format": "date-time" },
    "windowEnd": { "type": "string", "format": "date-time" },
    "coherence": {
      "type": "object",
      "properties": {
        "depth": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "truth": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "width": { "type": "number", "minimum": 0.0, "maximum": 1.0 }
      },
      "required": ["depth", "truth", "width"]
    },
    "overallScore": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
    "parallax": {
      "type": "object",
      "properties": {
        "tiltMagnitude": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "tiltThreshold": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "blinkTriggered": { "type": "boolean" }
      },
      "required": ["tiltMagnitude", "tiltThreshold", "blinkTriggered"]
    },
    "doctrineState": {
      "type": "string",
      "enum": ["SELF_NAVIGATING", "ADJACENT_CONVERGENT", "PATTERN_FOLLOWING"]
    },
    "lane": {
      "type": "string",
      "enum": ["LANE_A", "LANE_B", "LANE_C", "UNCLASSIFIED"]
    },
    "quarantineTriggered": { "type": "boolean" },
    "observationCount": { "type": "integer", "minimum": 0 },
    "sequenceNumber": { "type": "integer", "minimum": 0 }
  },
  "required": [
    "agentId", "windowStart", "windowEnd", "coherence", "overallScore",
    "parallax", "doctrineState", "lane", "quarantineTriggered",
    "observationCount", "sequenceNumber"
  ]
}
