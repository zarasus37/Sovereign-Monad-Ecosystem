{
  "name": "@sovereign/gnostic-engine",
  "version": "0.1.0",
  "description": "Volumetric 4D Gnostic Engine — Sovereign Monad Ecosystem",
  "type": "module",
  "private": true,
  "scripts": {
    "api": "uv run uvicorn api.gnostic_api:app --reload --port 8000",
    "dev": "uv run uvicorn api.gnostic_api:app --reload --port 8000",
    "test": "uv run pytest tests/ -v",
    "lint": "uv run ruff check src/",
    "type-check": "uv run mypy src/",
    "format": "uv run ruff format src/",
    "clean": "rm -rf build/ dist/ .eggs/ *.egg-info .pytest_cache .mypy_cache .ruff_cache"
  },
  "keywords": [
    "gnostic",
    "volumetric",
    "4d-engine",
    "sovereign-monad",
    "foraging",
    "market-truth"
  ],
  "author": "Cris Colon",
  "license": "Proprietary",
  "engines": {
    "node": ">=20.0.0",
    "python": ">=3.11.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "private"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/crisc-sovereign/the-sovereign",
    "directory": "gnostic-engine"
  }
}
