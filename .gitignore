# Binary / archive artifacts
*.zip
*.7z
*.tar.gz
*.sqlite
*.db
*.parquet
*.csv
*.jsonl
!monad-ecosystem/packages/hcd-monitor/tests/fixtures/*.jsonl
!logs/audit/signal-stream-traced.jsonl
# Canonical human-authored reward-model preference pairs (spec line 478) — the
# gating training artifact, authored + validate-worksheet-gated before commit.
# See gnosis-training/.gitignore + theo-techno-cosmo/plex/Review/REWARD_MODEL_PREFERENCE_PAIRS_GUIDE.md.
!gnosis-training/data/preference_pairs_ALL.jsonl
*.pdf
*.png
*.jpg
*.jpeg
*.gif
*.mp4
*.mov

# Temp / scratch
tmp/
temp/
scratch/
*.tmp
*.bak

# GitHub CLI binary (kept in .girignore as a manual mirror)
gh.exe

# Semiotic drift artifacts (post-cron, regenerated each cycle)
logs/semiotic_drift/

# Local Claude Code session data (plans, worktrees, settings) — never commit
.claude/

# Runtime test output written by the data-rail activator (regenerated each
# run with a fresh activationId + timestamp). The activator writes to
# cwd/logs/; the untracked monad-ecosystem/logs/ dir is the same output when
# cwd is the monad-ecosystem workspace root. Other logs/ content (analytics,
# audit reports, corpus) is committed source — do NOT ignore logs/ wholesale.
logs/data-rail-activation.json
monad-ecosystem/logs/
