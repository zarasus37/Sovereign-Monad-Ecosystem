{
  "name": "the-sovereign",
  "version": "2.4.0",
  "description": "Unified Theotechnological Gnostic Ecosystem — Layered Monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "bootstrap": "powershell -ExecutionPolicy Bypass -File scripts/bootstrap.ps1",
    "bootstrap:local": "powershell -ExecutionPolicy Bypass -File scripts/bootstrap-local.ps1",
    "sync": "powershell -ExecutionPolicy Bypass -File scripts/sync-canonical.ps1",
    "status": "powershell -ExecutionPolicy Bypass -File scripts/status.ps1",
    "check:layout": "powershell -ExecutionPolicy Bypass -File scripts/verify-layout.ps1",
    "dev": "pnpm --recursive dev",
    "dev:host": "pnpm --filter @sovereign/host start",
    "dev:mock-hepar": "pnpm --filter @sovereign/host mock-hepar",
    "build": "pnpm --filter=!public-activation-core --recursive build",
    "test": "pnpm --recursive test",
    "test:integration": "vitest run monad-ecosystem/tests/integration/",
    "typecheck": "pnpm --recursive run typecheck",
    "check:numerics": "node scripts/check-numeric-drift.mjs",
    "check:sign-types": "node scripts/check-sign-types-drift.mjs",
    "check:ttcl-artifacts": "node scripts/check-ttcl-artifacts-drift.mjs",
    "check:temple-grid": "node scripts/check-temple-grid.mjs",
    "check:council": "node scripts/check-council-registry.mjs",
    "validate": "pnpm check:layout && pnpm check:numerics && pnpm check:sign-types && pnpm check:ttcl-artifacts && pnpm check:temple-grid && pnpm check:council && pnpm typecheck && pnpm test:integration",
    "lint": "pnpm --recursive lint",
    "clean": "pnpm --recursive clean && Remove-Item -Recurse -Force node_modules, .pnpm-store -ErrorAction SilentlyContinue",
    "prepare": "husky install || true"
  },
  "keywords": [
    "gnostic",
    "theotechnological",
    "monad",
    "hepar",
    "sovereign",
    "ai-agents",
    "volumetric-engine"
  ],
  "author": "Cris Colon",
  "license": "SEE LICENSE IN docs/LICENSE.md",
  "workspaces": [
    "monad-ecosystem/packages/*",
    "gnostic-engine"
  ],
  "devDependencies": {
    "husky": "^9.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.6.0"
}
