{
  "name": "@sovereign/gnosis-core",
  "version": "0.2.0",
  "description": "Retrospective-only Gnosis integrity scaffold for decompression, hollow-convergence analysis, and personality plurality monitoring",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "dev:run": "ts-node src/cli.ts",
    "dev:registry": "ts-node src/registry-server.ts",
    "start": "node dist/cli.js",
    "start:registry": "node dist/registry-server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@sovereign/bus": "workspace:*",
    "@sovereign/types": "workspace:*",
    "kafkajs": "^2.2.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@vercel/node": "^5.8.22",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  },
  "files": [
    "dist",
    "src"
  ],
  "engines": {
    "node": ">=20.0.0"
  }
}
