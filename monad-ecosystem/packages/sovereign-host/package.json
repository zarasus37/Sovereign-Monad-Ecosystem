{
  "name": "@sovereign/host",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Sovereign Express host — gate-acl promote/bind + Cardia SSE (UMS Vector 4.3)",
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "exports": {
    ".": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./app": {
      "types": "./dist/app.d.ts",
      "import": "./dist/app.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "start:prod": "node dist/server.js",
    "mock-hepar": "tsx src/mock-hepar-server.ts",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/app.test.ts src/mock-hepar-server.test.ts src/metrics.test.ts"
  },
  "dependencies": {
    "@azure/identity": "^4.0.0",
    "@azure/keyvault-secrets": "^4.11.2",
    "@sovereign/cardia-funding-stream": "workspace:*",
    "@sovereign/gate-acl": "workspace:*",
    "@sovereign/types": "workspace:*",
    "cors": "^2.8.5",
    "ethers": "^6.11.0",
    "express": "^4.21.0"
  },
  "optionalDependencies": {
    "kafkajs": "^2.2.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
