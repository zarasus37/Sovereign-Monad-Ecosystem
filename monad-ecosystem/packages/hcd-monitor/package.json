{
  "name": "@sovereign/hcd-monitor",
  "version": "0.1.0",
  "description": "Human Capability Drift monitor — computes CHARTER.md §2.1 metrics from audit and bus logs",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "monitor": "node dist/cli.js",
    "generate-traced-window": "node scripts/generate-traced-window.mjs logs/audit/signal-stream-traced.jsonl"
  },
  "dependencies": {
    "@sovereign/bus": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
