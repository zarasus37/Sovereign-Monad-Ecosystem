{
  "name": "@sovereign/gate-acl",
  "version": "0.1.0",
  "description": "Shaliah PL→ACL hard gate — Principal Level ledger, signed ACL mandates, bus-side enforcement",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "test": "tsx --test src/gateAcl.test.ts src/runtime.adapters.test.ts src/closedLoop.test.ts src/logocTrade.test.ts src/plBridge.test.ts src/walletBind.test.ts",
    "demo": "tsx src/demo.ts",
    "closed-loop": "tsx src/closedLoop.ts",
    "closed-loop:interactive": "tsx src/closedLoop.ts --interactive",
    "paper:demo": "tsx src/paperCli.ts demo",
    "paper:session": "tsx src/paperCli.ts session",
    "paper:interactive": "tsx src/paperCli.ts interactive",
    "start": "tsx src/main.ts"
  },
  "dependencies": {
    "ethers": "^6.13.5",
    "ioredis": "^5.4.1",
    "kafkajs": "^2.2.4"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
