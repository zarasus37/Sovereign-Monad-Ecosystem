{
  "name": "@sovereign/cardia-funding-stream",
  "version": "0.1.0",
  "type": "module",
  "description": "Cardia Funding SSE Bridge — mountable Express router for funding status stream",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/cardiaFundingStream.ts",
    "start": "tsx src/cardiaFundingStream.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@sovereign/types": "workspace:*",
    "express": "^4.18.2",
    "kafkajs": "^2.2.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}